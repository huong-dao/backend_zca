PORT=3000
FRONTEND_ORIGIN=http://localhost:3001
DATABASE_URL=postgresql://postgres:123456@localhost:5432/zca?schema=public
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=access_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
# 64 hex chars (32 bytes), AES-256-GCM key for encrypting Zalo session credentials at rest
# ZALO_SESSION_ENCRYPTION_KEY=

# --- Background sync (BullMQ + Redis): master đồng bộ tên + globalId (cron) + child "quét nhóm" ---
# Bắt buộc true để bật cả job master lẫn quét nhóm con (cùng Redis).
# GROUP_SYNC_ENABLED=true
# BULL_REDIS_URL=redis://127.0.0.1:6379
# BULL_REDIS_HOST=127.0.0.1
# BULL_REDIS_PORT=6379
# GROUP_SYNC_CRON=0 */3 * * * *
# GROUP_SYNC_TZ=Asia/Ho_Chi_Minh
# Master tick: tối đa 20 grid id mỗi lần gọi getGroupInfo, tối đa 10 lần gọi mỗi lần worker chạy (mỗi ~3 phút một tick cron)
# GROUP_SYNC_GET_GROUP_INFO_BATCH=20
# GROUP_SYNC_MAX_INFO_CALLS_PER_RUN=10
# Giới hạn số bản ghi ZaloGroup pending lấy mỗi tick (mặc định 20*10=200 nếu không set)
# GROUP_SYNC_MAX_GROUPS_PER_FETCH=200

# Child quét nhóm: batch/continuation (cùng yêu cầu GROUP_SYNC_ENABLED=true)
# CHILD_GROUP_SYNC_GET_GROUP_INFO_BATCH=20
# CHILD_GROUP_SYNC_MAX_INFO_CALLS_PER_RUN=10
# CHILD_GROUP_SYNC_CONTINUE_DELAY_MS=180000
# CHILD_GROUP_SYNC_CACHE_TTL_SEC=604800
