PORT=3000
FRONTEND_ORIGIN=http://localhost:3001
DATABASE_URL=postgresql://postgres:123456@localhost:5432/zca?schema=public
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=access_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
# 64 hex chars (32 bytes), AES-256-GCM key for encrypting Zalo session credentials at rest
# ZALO_SESSION_ENCRYPTION_KEY=

# --- Optional: background sync (BullMQ + Redis) — đồng bộ tên nhóm + globalId từ Zalo ---
# GROUP_SYNC_ENABLED=false
# BULL_REDIS_URL=redis://127.0.0.1:6379
# BULL_REDIS_HOST=127.0.0.1
# BULL_REDIS_PORT=6379
# GROUP_SYNC_CRON=0 */3 * * * *
# GROUP_SYNC_TZ=Asia/Ho_Chi_Minh
# GROUP_SYNC_BATCH_SIZE=10
