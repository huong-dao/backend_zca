generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
}

enum MessageStatus {
  SENT
  FAILED
  RECALL
}

enum ZaloSessionStatus {
  ACTIVE
  EXPIRED
  INVALID
  PENDING_RELOGIN
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  role      UserRole
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model ZaloGroup {
  id          String             @id @default(uuid()) @db.Uuid
  groupName   String             @map("group_name") @db.VarChar(255)
  groupZaloId String             @unique @map("group_zalo_id") @db.VarChar(255)
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  accountMaps ZaloAccountGroup[]
  messages    Message[]

  @@map("zalo_groups")
}

model ZaloAccount {
  id         String             @id @default(uuid()) @db.Uuid
  zaloId     String?            @unique @map("zalo_id") @db.VarChar(255)
  phone      String?            @db.VarChar(50)
  name       String?            @db.VarChar(255)
  isMaster   Boolean            @default(false) @map("is_master")
  masterId   String?            @map("master_id") @db.Uuid
  groupCount Int                @default(0) @map("group_count")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")
  master     ZaloAccount?       @relation("ZaloAccountHierarchy", fields: [masterId], references: [id])
  children   ZaloAccount[]      @relation("ZaloAccountHierarchy")
  groupMaps  ZaloAccountGroup[]
  messages   Message[]
  session    ZaloSession?

  @@map("zalo_accounts")
}

model ZaloSession {
  id                   String            @id @default(uuid()) @db.Uuid
  zaloAccountId        String            @unique @map("zalo_account_id") @db.Uuid
  encryptedCredentials String            @map("encrypted_credentials") @db.Text
  status               ZaloSessionStatus @default(ACTIVE)
  lastValidatedAt      DateTime?         @map("last_validated_at")
  expiresAt            DateTime?         @map("expires_at")
  invalidReason        String?           @map("invalid_reason") @db.Text
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")
  zaloAccount          ZaloAccount       @relation(fields: [zaloAccountId], references: [id])

  @@index([status])
  @@map("zalo_sessions")
}

model ZaloAccountGroup {
  id            String      @id @default(uuid()) @db.Uuid
  zaloAccountId String      @map("zalo_account_id") @db.Uuid
  groupId       String      @map("group_id") @db.Uuid
  joinedAt      DateTime    @default(now()) @map("joined_at")
  zaloAccount   ZaloAccount @relation(fields: [zaloAccountId], references: [id])
  group         ZaloGroup   @relation(fields: [groupId], references: [id])

  @@map("zalo_account_groups")
}

model Message {
  id            String        @id @default(uuid()) @db.Uuid
  messageZaloId String?       @map("message_zalo_id") @db.VarChar(255)
  cliMsgId      String?       @map("cli_msg_id") @db.VarChar(255)
  uidFrom       String?       @map("uid_from") @db.VarChar(255)
  content       String        @db.Text
  senderId      String        @map("sender_id") @db.Uuid
  groupId       String        @map("group_id") @db.Uuid
  sentAt        DateTime?     @map("sent_at")
  status        MessageStatus
  createdAt     DateTime      @default(now()) @map("created_at")
  sender        ZaloAccount   @relation(fields: [senderId], references: [id])
  group         ZaloGroup     @relation(fields: [groupId], references: [id])

  @@index([senderId, groupId])
  @@map("messages")
}

model ApiKey {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  secretKey String   @unique @map("secret_key") @db.VarChar(255)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("api_keys")
}

model Configuration {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique @db.VarChar(255)
  value     String   @db.VarChar(255)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("configurations")
}
