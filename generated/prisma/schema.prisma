generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
}

enum MessageStatus {
  SENT
  FAILED
  RECALL
}

enum ZaloAccountFriendStatus {
  PENDING
  APPROVE
  CANCEL
}

/// Messaging is allowed only when `ACTIVE` (see messages send + recall, zalo-actions send-message).
enum ZaloAccountStatus {
  ACTIVE
  INACTIVE
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  role      UserRole
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  zaloLoginSessions ZaloLoginSession[]

  @@map("users")
}

/// Persisted Zalo QR session for zca-js (credentials encrypted at rest).
model ZaloLoginSession {
  id                   String   @id @db.Uuid
  userId               String   @map("user_id") @db.Uuid
  zaloUid              String   @map("zalo_uid") @db.VarChar(255)
  userProfile          Json     @map("user_profile")
  credentialsEncrypted Bytes    @map("credentials_encrypted")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([zaloUid])
  @@index([userId, zaloUid])
  @@map("zalo_login_sessions")
}

model ZaloGroup {
  id           String             @id @default(uuid()) @db.Uuid
  groupName    String             @map("group_name") @db.VarChar(255)
  /// Zalo group global id (e.g. EPHPVTP4JNKHS9M7F4QP0UK2I8978C00). Optional; unique when set. For server-side filtering only — do not expose in API responses.
  globalId     String?            @unique @map("global_id") @db.VarChar(255)
  /// Original group name when first captured; exposed in API responses.
  originName   String?            @map("origin_name") @db.VarChar(255)
  isUpdateName Boolean            @default(false) @map("is_update_name")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  accountMaps  ZaloAccountGroup[]
  messages     Message[]

  @@map("zalo_groups")
}

model ZaloAccountRelation {
  id        String   @id @default(uuid()) @db.Uuid
  masterId  String   @map("master_id") @db.Uuid
  childId   String   @map("child_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  master ZaloAccount @relation("MasterRelations", fields: [masterId], references: [id])
  child  ZaloAccount @relation("ChildRelations", fields: [childId], references: [id])

  @@unique([masterId, childId]) // tránh duplicate
  @@map("zalo_account_relations")
}

model ZaloAccount {
  id         String            @id @default(uuid()) @db.Uuid
  zaloId     String?           @unique @map("zalo_id") @db.VarChar(255)
  phone      String?           @db.VarChar(50)
  name       String?           @db.VarChar(255)
  isMaster   Boolean           @default(false) @map("is_master")
  /// `ACTIVE` required for send message / recall; new rows default to `INACTIVE` until enabled.
  status     ZaloAccountStatus @default(INACTIVE) @map("status")
  /// Soft delete: when true, this account is excluded from app queries and features (row kept for referential integrity).
  isDeleted  Boolean           @default(false) @map("is_deleted")
  deletedAt  DateTime?         @map("deleted_at")
  groupCount Int               @default(0) @map("group_count")
  groupData  Json?             @map("group_data")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")

  // 👉 relation mới
  masters  ZaloAccountRelation[] @relation("ChildRelations")
  children ZaloAccountRelation[] @relation("MasterRelations")

  groupMaps ZaloAccountGroup[]
  messages  Message[]

  friends  ZaloAccountFriend[] @relation("MasterFriends")
  friendOf ZaloAccountFriend[] @relation("FriendOf")

  @@index([isDeleted])
  @@index([status])
  @@map("zalo_accounts")
}

model ZaloAccountGroup {
  id            String      @id @default(uuid()) @db.Uuid
  groupZaloId   String      @map("group_zalo_id")
  zaloAccountId String      @map("zalo_account_id") @db.Uuid
  groupId       String      @map("group_id") @db.Uuid
  joinedAt      DateTime    @default(now()) @map("joined_at")
  zaloAccount   ZaloAccount @relation(fields: [zaloAccountId], references: [id])
  group         ZaloGroup   @relation(fields: [groupId], references: [id])

  @@unique([zaloAccountId, groupId])
  @@index([groupZaloId])
  @@map("zalo_account_groups")
}

model ZaloAccountFriend {
  id String @id @default(uuid()) @db.Uuid

  masterId String                  @map("master_id") @db.Uuid
  friendId String                  @map("friend_id") @db.Uuid
  status   ZaloAccountFriendStatus @default(PENDING)

  createdAt DateTime @default(now()) @map("created_at")

  master ZaloAccount @relation("MasterFriends", fields: [masterId], references: [id])
  friend ZaloAccount @relation("FriendOf", fields: [friendId], references: [id])

  @@unique([masterId, friendId])
  @@map("zalo_account_friends")
}

/// One row per Zalo bubble. Text + N files in a single send: first bubble has `parent_id` null, file rows
/// set `parent_id` to the text row (same `sent_at` batch). `POST /messages/undo/:id` on the parent undoes
/// the parent’s Zalo bubble then each child row’s bubble.
model Message {
  id            String        @id @default(uuid()) @db.Uuid
  messageZaloId String?       @map("message_zalo_id") @db.VarChar(255)
  cliMsgId      String?       @map("cli_msg_id") @db.VarChar(255)
  uidFrom       String?       @map("uid_from") @db.VarChar(255)
  content       String        @db.Text
  senderId      String        @map("sender_id") @db.Uuid
  groupId       String        @map("group_id") @db.Uuid
  /// If set, this bubble (e.g. a file) belongs to a multi-bubble send whose text row is `parentId`.
  parentId      String?       @map("parent_id") @db.Uuid
  sentAt        DateTime?     @map("sent_at")
  status        MessageStatus
  createdAt     DateTime      @default(now()) @map("created_at")
  sender        ZaloAccount   @relation(fields: [senderId], references: [id])
  group         ZaloGroup     @relation(fields: [groupId], references: [id])
  parent        Message?      @relation("MessageParent", fields: [parentId], references: [id], onDelete: SetNull)
  childMessages Message[]     @relation("MessageParent")

  @@index([parentId])
  @@index([senderId, groupId])
  @@map("messages")
}

model ApiKey {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  secretKey String   @unique @map("secret_key") @db.VarChar(255)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("api_keys")
}

model Configuration {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique @db.VarChar(255)
  value     String   @db.VarChar(255)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("configurations")
}
